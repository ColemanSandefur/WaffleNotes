---
import Image from "astro/components/Image.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const postData = post.data;
const { title, description, coverImage, pubDate } = postData;
const formattedDate = pubDate.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<a
  href=`/posts/${post.id}`
  class={"border border-border p-4 flex flex-col sm:flex-row gap-4 rounded-sm hover:bg-border/30 transition duration-200 ease-in-out hover:shadow-md"}
>
  <div class="flex sm:h-26 aspect-video overflow-hidden rounded-md">
    <Image
      src={coverImage}
      alt={title}
      width={640}
      height={360}
      sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
      class="h-full w-full object-cover"
      loading="lazy"
    />
  </div>
  <div class="flex flex-col gap-2 grow flex-1">
    <p class="text-xs font-mono text-primary font-light uppercase">
      {formattedDate}
    </p>
    <p class="font-serif text-lg text-primary">{title}</p>
    <p class="text-sm text-muted-foreground line-clamp-2">
      {description}
    </p>
  </div>
</a>
