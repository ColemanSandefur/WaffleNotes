---
import ContentSection from "./ContentSection.astro";
import HeaderLink from "./HeaderLink.astro";
import menuItems from "../data/navigation.json";

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  return href === pathname || pathname.startsWith(href + "/");
};
---

<header class="border-b border-primary/50">
  <nav>
    <div class="flex flex-col items-center p-4">
      <div
        class="w-full max-w-2xl flex flex-row py-2 justify-between items-center"
      >
        <a
          href="/"
          class="text-3xl font-stretch-extra-expanded text-primary font-bold font-serif"
          >WaffleNotes</a
        >

        <!-- Desktop Menu -->
        <div class="hidden sm:flex flex-row gap-4 text-lg align-middle">
          {
            menuItems.map((item) => (
              <HeaderLink href={item.link}>{item.name}</HeaderLink>
            ))
          }
        </div>

        <!-- Mobile Menu Toggle Button -->
        <button
          id="menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle Navigation Menu"
          class="sm:hidden flex items-center justify-center p-2 text-primary focus:outline-hidden cursor-pointer"
        >
          <svg
            class="h-6 w-6 stroke-current stroke-2 fill-none"
            viewBox="0 0 24 24"
          >
            <line x1="4" y1="12" x2="20" y2="12" class="line-1"></line>
            <line x1="4" y1="12" x2="20" y2="12" class="line-2"></line>
            <line x1="4" y1="12" x2="20" y2="12" class="line-3"></line>
          </svg>
        </button>
      </div>

      <!-- Mobile Menu Container with Grid Height Transition -->
      <div
        id="mobile-menu"
        class="grid transition-[grid-template-rows] duration-300 ease-in-out w-full max-w-2xl sm:hidden"
      >
        <div class="overflow-hidden min-h-0">
          <div
            class="flex flex-col gap-2 pt-2 pb-4 border-t border-primary/20 mt-2"
          >
            {
              menuItems.map((item) => (
                <a
                  href={item.link}
                  class={`font-mono text-sm py-2 px-3 hover:bg-primary/10 transition-colors ${
                    isActive(item.link)
                      ? "font-bold border-l-2 border-primary pl-2 text-primary"
                      : "text-primary/80"
                  }`}
                >
                  {item.name}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  /* Scoped CSS for hamburger to X animation */
  #menu-toggle .line-1,
  #menu-toggle .line-2,
  #menu-toggle .line-3 {
    transform-origin: 12px 12px;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  /* Closed State (Default offsets) */
  #menu-toggle .line-1 {
    transform: translateY(-6px);
  }
  #menu-toggle .line-3 {
    transform: translateY(6px);
  }

  /* Open State (Rotations) */
  #menu-toggle[aria-expanded="true"] .line-1 {
    transform: translateY(0) rotate(45deg);
  }
  #menu-toggle[aria-expanded="true"] .line-2 {
    opacity: 0;
  }
  #menu-toggle[aria-expanded="true"] .line-3 {
    transform: translateY(0) rotate(-45deg);
  }

  /* Drawer Height Animation */
  #mobile-menu {
    grid-template-rows: 0fr;
  }
  #mobile-menu.is-open {
    grid-template-rows: 1fr;
  }
</style>

<script>
  function setupMobileMenu() {
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    if (menuToggle && mobileMenu) {
      // Avoid duplicate event listeners if setup is called multiple times
      menuToggle.replaceWith(menuToggle.cloneNode(true));
      const newToggle = document.getElementById("menu-toggle");
      const newMenu = document.getElementById("mobile-menu");

      if (newToggle && newMenu) {
        newToggle.addEventListener("click", () => {
          const isExpanded = newToggle.getAttribute("aria-expanded") === "true";
          newToggle.setAttribute("aria-expanded", String(!isExpanded));
          newMenu.classList.toggle("is-open");
        });
      }
    }
  }

  // Set up on initial load
  setupMobileMenu();

  // Support Astro View Transitions
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
