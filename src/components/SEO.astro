---
import fallbackImage from "../images/mountain.jpg";
import type { ImageMetadata } from "astro";

export interface Props {
  title: string;
  description?: string;
  image?: string | ImageMetadata;
  type?: "website" | "article";
  articleData?: {
    publishDate: Date;
    updatedDate?: Date;
    author: string;
  };
}

const {
  title,
  description,
  image,
  type = "website",
  articleData,
} = Astro.props;

// Determine formatting of page title
const formattedTitle =
  title === "Home" || title === "WaffleNotes"
    ? "WaffleNotes | Faith-Centered Reflections & Notes"
    : `${title} | WaffleNotes`;

// Define a fallback description
const fallbackDescription =
  "A simple space for thoughtful reflections, Bible-centered notes, and encouraging writing associated with the Churches of Christ.";
const metaDescription = description || fallbackDescription;

// Construct full canonical and image URLs
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://wafflenotes.netlify.app",
).href;

const resolvedImageSrc =
  typeof image === "string"
    ? image
    : typeof image === "object" && image !== null && "src" in image
      ? (image as ImageMetadata).src
      : fallbackImage.src;

const imageUrl = new URL(
  resolvedImageSrc,
  Astro.site || "https://wafflenotes.netlify.app",
).href;

// Structure JSON-LD based on page type
const jsonLd =
  type === "article" && articleData
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description: metaDescription,
        image: imageUrl,
        datePublished: articleData.publishDate.toISOString(),
        ...(articleData.updatedDate && {
          dateModified: articleData.updatedDate.toISOString(),
        }),
        author: {
          "@type": "Person",
          name: articleData.author,
        },
        publisher: {
          "@type": "Organization",
          name: "WaffleNotes",
          logo: {
            "@type": "ImageObject",
            url: new URL(
              "/favicon.svg",
              Astro.site || "https://wafflenotes.netlify.app",
            ).href,
          },
        },
        mainEntityOfPage: canonicalURL,
      }
    : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "WaffleNotes",
        url: canonicalURL,
        description: metaDescription,
      };
---

<!-- Primary Meta Tags -->
<title>{formattedTitle}</title>
<meta name="title" content={formattedTitle} />
<meta name="description" content={metaDescription} />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content="index, follow" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:image" content={imageUrl} />
<meta property="og:site_name" content="WaffleNotes" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={imageUrl} />

<!-- Structured JSON-LD Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
