---
import { BookOpenTextIcon } from "@lucide/astro";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import SeriesPartBadge from "./SeriesPartBadge.astro";

interface Props {
  series: CollectionEntry<"series">;
  numPosts: number;
  latestPost?: CollectionEntry<"post">;
}

const { series, numPosts, latestPost } = Astro.props;
const seriesData = series.data;
const { title, description, coverImage } = seriesData;
const formattedDate = latestPost?.data.pubDate.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<a
  href=`/series/${series.id}`
  class={"border border-border p-4 flex flex-col sm:flex-row gap-4 rounded-sm hover:bg-border/30 transition duration-200 ease-in-out hover:shadow-md"}
>
  <div class="flex sm:h-26 aspect-video overflow-hidden rounded-md">
    <Image
      src={coverImage}
      alt={title}
      width={640}
      height={360}
      sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
      class="h-full w-full object-cover"
      loading="lazy"
    />
  </div>
  <div class="flex flex-col gap-2 grow flex-1">
    <div class="flex flex-row items-center gap-2 justify-between">
      {
        formattedDate ? (
          <p class="text-xs font-mono text-primary font-light uppercase">
            {formattedDate}
          </p>
        ) : (
          <p class="text-xs font-mono text-muted-foreground font-light uppercase">
            Coming Soon...
          </p>
        )
      }
      <SeriesPartBadge size="sm" numPosts={numPosts} />
    </div>
    <p class="font-serif text-lg text-primary">{title}</p>
    <p class="text-sm text-muted-foreground line-clamp-2">
      {description}
    </p>
  </div>
</a>
