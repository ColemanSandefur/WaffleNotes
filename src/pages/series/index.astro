---
import ContentSection from "@/components/ContentSection.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

const posts = await getCollection(
  "post",
  (post) => post.data.draft === false,
).then((value) =>
  value.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
);

function getLatestPost(series: CollectionEntry<"series">) {
  return posts.find(
    (post) => post.data.series?.id === series.id && post.data.draft === false,
  );
}

function getNumPosts(series: CollectionEntry<"series">) {
  return posts.filter(
    (post) => post.data.series?.id === series.id && post.data.draft === false,
  ).length;
}

const series = await getCollection(
  "series",
  (series) => series.data.draft === false,
).then((value) =>
  value.sort(
    (a, b) =>
      (getLatestPost(b)?.data.pubDate.valueOf() ?? 0) -
      (getLatestPost(a)?.data.pubDate.valueOf() ?? 0),
  ),
);

export type SearchIndexData = {
  id: string;
  index: number;
  title: string;
  description: string;
  date: number;
};

// Serialize metadata into plain JSON
const searchIndexData = series.map((s, index) => {
  const latestPost = getLatestPost(s);
  return {
    id: s.id,
    index: index,
    title: s.data.title,
    description: s.data.description,
    date: latestPost?.data.pubDate.valueOf() ?? 0,
  } satisfies SearchIndexData;
});

import * as aboutPost from "@/content/pages/series.md";
import SeriesViewCard from "@/components/SeriesViewCard.astro";
import { ArrowLeftIcon, ArrowRightIcon } from "@lucide/astro";
const compiled = await aboutPost.compiledContent();
const { title, description } = aboutPost.frontmatter;
---

<BaseLayout title={title} description={description}>
  <ContentSection>
    <h1 class="text-4xl font-serif font-bold text-primary mt-12">
      {title}
    </h1>
    <p class="pt-4 text-muted-foreground">
      {description}
    </p>

    {
      compiled && (
        <div class="prose prose-themed post-content mt-8">
          <Fragment set:html={compiled} />
        </div>
      )
    }
    <div class="flex flex-col sm:flex-row gap-3 mt-12">
      <span class="flex flex-col grow gap-2">
        <label for="search" class="font-mono text-sm text-primary"
          >Search series</label
        >
        <input
          id="search"
          type="text"
          placeholder="Search by title or keyword..."
          class="px-4 h-10 border border-border rounded-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
        />
      </span>
      <span class="flex flex-col gap-2">
        <label for="sort" class="font-mono text-sm text-primary">Sort by</label>
        <select
          id="sort"
          class="px-4 h-10 border border-border rounded-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
        >
          <option value="newest">Newest</option>
          <option value="oldest">Oldest</option>
        </select>
      </span>
    </div>
    <div class="flex flex-row flex-wrap mt-4">
      <p
        class="text-xs font-mono bg-primary text-primary-foreground py-1 px-4 rounded-full"
      >
        All Series
      </p>
    </div>

    <!-- Cards Container -->
    <div id="series-container" class="flex flex-col gap-4 mt-12">
      {
        series.map((s) => {
          const latestDate = getLatestPost(s)?.data.pubDate.valueOf() ?? 0;
          return (
            <div
              class="series-item transition-all duration-200"
              data-id={s.id}
              data-date={latestDate}
            >
              <SeriesViewCard
                series={s}
                numPosts={getNumPosts(s)}
                latestPost={getLatestPost(s)}
              />
            </div>
          );
        })
      }
    </div>

    <p
      id="no-results"
      class="hidden text-muted-foreground font-mono text-center py-12"
    >
      No matching series found.
    </p>

    <!-- Pagination Controls -->
    <nav
      id="pagination-controls"
      class="flex justify-between items-center mt-8 font-mono text-sm"
    >
      <button
        id="prev-page"
        class="flex flex-row items-center gap-2 px-4 py-2 border border-border rounded-sm disabled:opacity-30 disabled:cursor-not-allowed hover:bg-muted"
      >
        <ArrowLeftIcon class="size-4" />
        Previous
      </button>
      <span id="page-info" class="text-muted-foreground">Page 1 of 1</span>
      <button
        id="next-page"
        class="flex flex-row items-center gap-2 px-4 py-2 border border-border rounded-sm disabled:opacity-30 disabled:cursor-not-allowed hover:bg-muted"
      >
        Next
        <ArrowRightIcon class="size-4" />
      </button>
    </nav>
  </ContentSection>
</BaseLayout>

<style>
  #series-container {
    transition:
      transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.25s ease-in-out;
  }

  .slide-out-left {
    transform: translateX(-30px);
    opacity: 0;
  }

  .slide-out-right {
    transform: translateX(30px);
    opacity: 0;
  }

  .slide-in {
    animation: slideIn 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: var(--slide-from);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>

<script
  type="application/json"
  id="search-data"
  set:html={JSON.stringify(searchIndexData)}
/>

<script>
  import Fuse from "fuse.js";
  import type { SearchIndexData } from "./index.astro";

  function initSearch() {
    const searchInput = document.getElementById("search") as HTMLInputElement;
    const sortSelect = document.getElementById("sort") as HTMLSelectElement;
    const container = document.getElementById("series-container");
    const noResults = document.getElementById("no-results");
    const prevButton = document.getElementById(
      "prev-page",
    ) as HTMLButtonElement;
    const nextButton = document.getElementById(
      "next-page",
    ) as HTMLButtonElement;
    const pageInfo = document.getElementById("page-info");
    const dataScript = document.getElementById("search-data");

    if (!searchInput || !sortSelect || !container || !dataScript) return;

    const searchIndexData = JSON.parse(
      dataScript.textContent || "[]",
    ) as SearchIndexData[];

    const ITEMS_PER_PAGE = 10;
    let currentPage = 1;

    // Initialize Fuse.js
    const fuse = new Fuse(searchIndexData, {
      keys: ["title", "description"],
      threshold: 0.3,
      ignoreLocation: true,
    });

    function updateView() {
      if (!container) return;

      const query = searchInput.value.trim();
      const sortBy = sortSelect.value;
      const items = Array.from(
        container.getElementsByClassName("series-item"),
      ) as HTMLElement[];

      let matchedIds = new Set<string>();

      if (query.length > 0) {
        const results = fuse.search(query);
        results.forEach((r) => matchedIds.add(r.item.id));
      } else {
        searchIndexData.forEach((item) => matchedIds.add(item.id));
      }

      let filteredItems = items.filter((item) => {
        const id = item.getAttribute("data-id");
        return id ? matchedIds.has(id) : false;
      });

      if (query.length > 0) {
        const orderMap = new Map();
        fuse
          .search(query)
          .forEach((res, idx) => orderMap.set(res.item.id, idx));
        filteredItems.sort((a, b) => {
          const idA = a.getAttribute("data-id") || "";
          const idB = b.getAttribute("data-id") || "";
          return (orderMap.get(idA) ?? 0) - (orderMap.get(idB) ?? 0);
        });
      } else {
        filteredItems.sort((a, b) => {
          const dateA = Number(a.getAttribute("data-date") || 0);
          const dateB = Number(b.getAttribute("data-date") || 0);
          return sortBy === "newest" ? dateB - dateA : dateA - dateB;
        });
      }

      const totalPages = Math.ceil(filteredItems.length / ITEMS_PER_PAGE) || 1;
      if (currentPage > totalPages) {
        currentPage = 1;
      }

      const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
      const endIndex = startIndex + ITEMS_PER_PAGE;

      items.forEach((item) => (item.style.display = "none"));

      filteredItems.forEach((item, index) => {
        container.appendChild(item);
        if (index >= startIndex && index < endIndex) {
          item.style.display = "";
        }
      });

      if (noResults) {
        if (filteredItems.length === 0) {
          noResults.classList.remove("hidden");
          if (pageInfo) pageInfo.style.display = "none";
          if (prevButton) prevButton.style.display = "none";
          if (nextButton) nextButton.style.display = "none";
        } else {
          noResults.classList.add("hidden");
          if (pageInfo) {
            pageInfo.style.display = "";
            pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
          }
          if (prevButton) {
            prevButton.style.display = "";
            prevButton.disabled = currentPage === 1;
          }
          if (nextButton) {
            nextButton.style.display = "";
            nextButton.disabled = currentPage === totalPages;
          }
        }
      }
    }

    function transitionPage(direction: "next" | "prev", action: () => void) {
      if (!container) return;

      const outClass =
        direction === "next" ? "slide-out-left" : "slide-out-right";
      container.classList.add(outClass);

      setTimeout(() => {
        action();
        container.classList.remove(outClass);
        const fromVal = direction === "next" ? "30px" : "-30px";
        container.style.setProperty("--slide-from", fromVal);
        container.classList.add("slide-in");

        setTimeout(() => {
          container.classList.remove("slide-in");
        }, 250);
      }, 200);
    }

    searchInput.addEventListener("input", () => {
      currentPage = 1;
      updateView();
    });

    sortSelect.addEventListener("change", () => {
      currentPage = 1;
      updateView();
    });

    prevButton?.addEventListener("click", () => {
      if (currentPage > 1) {
        transitionPage("prev", () => {
          currentPage--;
          updateView();
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    });

    nextButton?.addEventListener("click", () => {
      const query = searchInput.value.trim();
      let matchedCount = searchIndexData.length;
      if (query.length > 0) {
        matchedCount = fuse.search(query).length;
      }
      const totalPages = Math.ceil(matchedCount / ITEMS_PER_PAGE);

      if (currentPage < totalPages) {
        transitionPage("next", () => {
          currentPage++;
          updateView();
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    });

    updateView();
  }

  initSearch();
  document.addEventListener("astro:page-load", initSearch);
</script>
