---
import ContentSection from "@/components/ContentSection.astro";
import PostCard from "@/components/PostCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const posts = await getCollection(
  "post",
  (post) => post.data.draft === false,
).then((value) =>
  value.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
);

const firstPost = posts[0];
const morePosts = posts.slice(1, 10);
---

<BaseLayout
  title="Home"
  description="WaffleNotes is a simple space for thoughtful reflections, Bible-centered notes, and encouraging writing associated with the Churches of Christ."
>
  <div class="flex flex-col items-center p-4">
    <div class="w-full max-w-2xl">
      <div class="grid grid-cols-1 gap-4 mt-4">
        <p class="text-end font-mono text-primary font-light text-sm">
          Latest post
        </p>
        <Image
          src={firstPost.data.coverImage}
          alt={firstPost.data.title}
          width={1200}
          height={675}
          sizes="(min-width: 768px) 80vw, 100vw"
          class="md:col-span-1 rounded-xl"
          loading="eager"
        />
        <div class="flex flex-col gap-4">
          <h1 class="font-serif text-4xl text-primary">
            {firstPost.data.title}
          </h1>
          <p class="text-foreground/70">
            {firstPost.data.description}
          </p>
          <a
            href={`/posts/${firstPost.id}`}
            class="col-start-3 underline font-mono text-primary"
            >Read Full Post</a
          >
        </div>
      </div>

      <div
        class="flex flex-row justify-center gap-8 text-sm text-primary my-16"
      >
        <span>•</span>
        <span>•</span>
        <span>•</span>
      </div>
    </div>
  </div>
  <div class="flex flex-col items-center p-4">
    <div class="w-full max-w-5xl">
      <h2 class="text-2xl text-primary">Recent Entries</h2>
      <span class="block w-8 border-b-[1.5px] border-primary"></span>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-x-4 gap-y-8 mt-8">
        {morePosts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </div>
</BaseLayout>
