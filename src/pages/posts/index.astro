---
import ContentSection from "@/components/ContentSection.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArchiveSearch, {
  type PostSearchItem,
} from "@/components/preact/ArchiveSearch";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";

const posts = await getCollection(
  "post",
  (post) => post.data.draft === false,
).then((value) =>
  value.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
);

// Map items for Preact, including pre-rendered card templates via Astro components
// Note: Preact islands can render serializable props or HTML strings cleanly.
const searchItems = await Promise.all(
  posts.map(async (post) => {
    const optimizedImage = await getImage({
      src: post.data.coverImage,
      width: 640,
      height: 360,
    });

    return {
      id: post.id,
      title: post.data.title,
      description: post.data.description,
      date: post.data.pubDate.valueOf(),
      coverImage: {
        src: optimizedImage.src,
        srcSet: optimizedImage.srcSet.attribute, // Astro's generated srcset string
        width: 640,
        height: 360,
      },
    } satisfies PostSearchItem;
  }),
);
---

<BaseLayout
  title="Posts"
  description="A collection of reflections, essays, and other study notes from WaffleNotes."
>
  <ContentSection>
    <h1 class="text-4xl font-serif font-bold text-primary mt-12">
      The Archive
    </h1>
    <p class="pt-4 text-muted-foreground">
      A collection of reflections, essays, and other writings.
    </p>

    <ArchiveSearch client:load items={searchItems} type="post" />
  </ContentSection>
</BaseLayout>
