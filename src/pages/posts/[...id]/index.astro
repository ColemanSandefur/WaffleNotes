---
import AudioComponent from "@/components/AudioComponent.astro";
import ContentSection from "@/components/ContentSection.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { CollectionEntry } from "astro:content";
import { getCollection, getEntry, render } from "astro:content";
import { Image } from "astro:assets";
import type { InferEntrySchema } from "astro:content";

interface Props {
  post: CollectionEntry<"post">;
}

export async function getStaticPaths() {
  const posts = await getCollection("post");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const authorObj = await getEntry(
  post.data.author.collection,
  post.data.author.id,
);

const author =
  authorObj?.data ??
  ({
    name: "Unknown Author",
  } satisfies InferEntrySchema<"author">);

const seriesObj = post.data.series
  ? await getEntry(post.data.series.collection, post.data.series.id)
  : undefined;

const series = seriesObj?.data;

function getInitials(name: string) {
  return name
    .split(" ", 2)
    .map((val) => (val ? val.charAt(0).toLocaleUpperCase() : val))
    .join("");
}

const authorName = author.name;
const authorInitials = getInitials(author.name);
const authorImage = author.avatar;

const coverImage = post.data.coverImage;
const audioUrl = post.data.audioUrl;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={coverImage}
  type="article"
  articleData={{
    publishDate: post.data.pubDate,
    updatedDate: post.data.updatedDate,
    author: authorName,
  }}
>
  <section
    class="relative isolate flex min-h-[60vh] w-full bg-background overflow-hidden"
  >
    <!-- Image Component (No mask needed here anymore) -->
    <Image
      src={coverImage}
      alt="Descriptive text"
      width={1920}
      height={1080}
      sizes="100vw"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      loading="eager"
    />

    <!-- Gradient Overlay (Replaces the mask) -->
    <!-- 
      This creates a gradient that starts transparent at the top,
      and fades to your site's background color (e.g., dark or light) at the bottom.
      We use a higher opacity (e.g., /90) at the bottom to guarantee text contrast.
    -->
    <div
      class="absolute inset-0 -z-10 bg-linear-to-b from-transparent via-background/10 to-background/90"
    >
    </div>

    <!-- 2. The Gradient Blur Scrim -->
    <!-- This div is what actually creates the blurred area -->
    <div
      class="absolute inset-x-0 bottom-0 h-2/3 backdrop-blur-lg bg-background/30"
      style={`
      -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 100%);
      mask-image: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 100%);
    `}
    >
    </div>

    <!-- 2. The Gradient Blur Scrim -->
    <!-- This div is what actually creates the blurred area -->
    <div
      class="absolute inset-x-0 bottom-0 h-2/3 backdrop-blur-md bg-background/30"
      style={`
      -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 100%);
      mask-image: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 100%);
    `}
    >
    </div>

    <!-- Content -->
    <div class="relative z-10 w-full flex flex-col justify-end pb-2">
      <div class="">
        <ContentSection>
          <div class="flex flex-col gap-4">
            <div>
              <h1 class="text-5xl text-foreground">
                {post.data.title}
              </h1>
              <p class="mt-4 text-md text-foreground/70 italic">
                {post.data.description}
              </p>
            </div>
            <span class="block border-b border-b-foreground/25"></span>
            <div class="flex flex-row text-foreground/80 gap-2">
              <!-- Replace your current initials div with this -->
              <div
                class="size-10 flex-none aspect-square bg-primary text-primary-foreground rounded-md flex justify-center items-center font-mono text-2xl"
              >
                {
                  authorImage ? (
                    <Image
                      src={authorImage}
                      alt={authorName}
                      width={120}
                      height={120}
                      class="rounded-md object-cover"
                    />
                  ) : (
                    <p class="leading-none m-0">{authorInitials}</p>
                  )
                }
              </div>
              <div class="flex flex-col">
                <span class="font-mono uppercase text-xs text-primary"
                  >Written by</span
                >
                <p class="">{authorName}</p>
              </div>
              <div class="flex flex-col ml-auto text-right">
                <span class="font-mono uppercase text-xs text-primary"
                  >Published</span
                >
                <p class="">{post.data.pubDate.toDateString()}</p>
              </div>
            </div>
          </div>
        </ContentSection>
      </div>
    </div>
  </section>

  <ContentSection>
    {
      (series || audioUrl) && (
        <Fragment>
          <div class="flex flex-col gap-2 mt-2">
            {
              series && (
                <div class="p-2 flex flex-col sm:flex-row gap-2 gap-y-4 rounded-sm border border-border">
                  <div class="flex flex-row gap-2">
                    <div class="size-10 aspect-square rounded-md bg-primary text-primary-foreground flex justify-center items-center text-2xl">📖</div>
                    <div class="flex flex-col">
                      <span class="font-mono text-xs text-muted-foreground">
                        This lesson is part of a series:
                      </span>
                      <p class="font-serif text-base text-primary">{series.title}</p>
                    </div>
                  </div>
                  <div class="flex flex-col ml-auto justify-center w-full sm:w-fit">
                    <a
                      href=`/series/${seriesObj.id}`
                      class="bg-primary text-primary-foreground rounded-md grow-0 py-2 px-3 text-sm sm:w-fit text-center sm:text-left"
                    >
                      View Series
                    </a>
                  </div>
                </div>
              )
            }
            {
              audioUrl && (
                <AudioComponent src={audioUrl} />
              )
            }
          </div>
          <div class="flex flex-row justify-center gap-8 text-sm text-primary my-8">
            <span>•</span>
            <span>•</span>
            <span>•</span>
          </div>
        </Fragment>
      )
    }
    <div class="prose prose-themed post-content mt-8">
      <Content />
    </div>
  </ContentSection>
</BaseLayout>
